{
  "notes": "Smoke test config — small, isolated outputs and short runs.",
  "eval_suite": "configs/eval_suite.json",
  "output_layout": {
    "checkpoints": "checkpoints/smoke",
    "training_logs": "outputs/smoke_train_logs",
    "evaluation_outputs": "outputs/smoke_eval",
    "qualitative_outputs": "outputs/smoke_qualitative",
    "report_assets": "outputs/smoke_report_assets",
    "figures": "outputs/smoke_figures"
  },
  "runs": [
    {
      "run_name": "mlp_smoke_seed0_main",
      "kind": "train_eval",
      "group": "main",
      "report_section": "main_results",
      "model": "mlp",
      "difficulty": "easy",
      "seed": 0,
      "total_timesteps": 2048,
      "ppo_config": {
        "target_kl": 0.03,
        "minibatch_size": 128,
        "update_epochs": 4,
        "policy_lr": 2.5e-4,
        "value_lr": 5e-05,
        "clip_coef": 0.2,
        "value_coef": 0.25,
        "entropy_coef": 0.01
      },
      "expected_outputs": [
        "checkpoints/smoke/mlp_smoke_seed0_main.pt",
        "outputs/smoke_train_logs/mlp_smoke_seed0_main_train_summary.json",
        "outputs/smoke_eval/mlp_smoke_seed0_main_summary.json",
        "outputs/smoke_eval/mlp_smoke_seed0_main_easy_episodes.csv"
      ]
    },
    {
      "run_name": "gnn_smoke_seed0_main",
      "kind": "train_eval",
      "group": "main",
      "report_section": "main_results",
      "model": "gnn",
      "difficulty": "easy",
      "seed": 0,
      "total_timesteps": 2048,
      "model_kwargs": {
        "latent_dim": 128,
        "num_layers": 2,
        "dropout": 0.0
      },
      "ppo_config": {
        "target_kl": 0.03,
        "minibatch_size": 128,
        "update_epochs": 4,
        "policy_lr": 2.5e-4,
        "value_lr": 5e-05,
        "clip_coef": 0.2,
        "value_coef": 0.25,
        "entropy_coef": 0.01
      },
      "expected_outputs": [
        "checkpoints/smoke/gnn_smoke_seed0_main.pt",
        "outputs/smoke_train_logs/gnn_smoke_seed0_main_train_summary.json",
        "outputs/smoke_eval/gnn_smoke_seed0_main_summary.json",
        "outputs/smoke_eval/gnn_smoke_seed0_main_easy_episodes.csv"
      ]
    },
      {
      "run_name": "predictive_smoke_seed0_h3_main",
      "kind": "train_eval",
      "group": "main",
      "report_section": "main_results",
      "model": "predictive",
      "difficulty": "easy",
      "seed": 0,
      "total_timesteps": 2048,
      "model_kwargs": {
        "horizon": 3,
        "aux_coef": 0.2,
        "latent_dim": 128,
        "num_layers": 2,
        "dropout": 0.0
      },
      "ppo_config": {
        "rollout_steps": 2048,
        "minibatch_size": 256,
        "update_epochs": 8,
        "policy_lr": 2.0e-4,
        "value_lr": 4.0e-4,
        "target_kl": 0.04,
        "clip_coef": 0.2,
        "value_coef": 0.25,
        "entropy_coef": 0.02,
        "lr_schedule": true,
        "aux_warmup_percent": 0.4
      },
      "expected_outputs": [
        "checkpoints/smoke/predictive_smoke_seed0_h3_main.pt",
        "outputs/smoke_train_logs/predictive_smoke_seed0_h3_main_train_summary.json",
        "outputs/smoke_eval/predictive_smoke_seed0_h3_main_summary.json",
        "outputs/smoke_eval/predictive_smoke_seed0_h3_main_easy_episodes.csv"
      ]
    }
   ]
}
